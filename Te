✅ 3. Aikau Widget (FIXED — no DOM issues)

example/widgets/HelloWidget.js

define([
   "dojo/_base/declare",
   "dojo/_base/lang",
   "alfresco/core/Core",
   "alfresco/html/Label"
], function(declare, lang, Core, Label) {
   return declare([Core], {
      postCreate: function() {
         this.inherited(arguments);
         console.log("HelloWidget loaded");
         this.alfSubscribe(
            "GET_HELLO_MESSAGE_SUCCESS",
            lang.hitch(this, this.updateMessage)
         );
         this.alfPublish("GET_HELLO_MESSAGE", {
            alfResponseTopic: "GET_HELLO_MESSAGE"
         });
      },
      updateMessage: function(payload) {
         console.log("Response received:", payload);
         var message = payload.message || "No message";
         new Label({
            label: message
         }).placeAt(this.domNode);
      }
   });
});

