define([
   "dojo/_base/declare",
   "dojo/_base/lang",
   "alfresco/core/Core",
   "alfresco/html/Label"
], function(declare, lang, Core, Label) {
   return declare([Core], {
      postCreate: function() {
         this.inherited(arguments);
         // ? Listen for response
         this.alfSubscribe("GET_HELLO_MESSAGE_SUCCESS",
            lang.hitch(this, this.updateMessage));
         // ? Trigger service
         this.alfPublish("GET_HELLO_MESSAGE", {
            alfResponseTopic: "GET_HELLO_MESSAGE"
         });
      },
      updateMessage: function(payload) {
         var message = payload.message || "No message";
         // ? Dynamically create label
         this.messageLabel = new Label({
            label: message
         });
         this.messageLabel.placeAt(this.domNode);
      }
   });
});

