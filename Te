⚙️ 4. SERVICE (XHR LAYER)

📄 DocCountService.js

define([
  "dojo/_base/declare",
  "alfresco/services/BaseService",
  "alfresco/core/CoreXhr",
  "dojo/_base/lang"
], function(declare, BaseService, CoreXhr, lang) {
  return declare([BaseService, CoreXhr], {
    registerSubscriptions: function() {
      this.alfSubscribe(
        "DOC_COUNT_REQUEST",
        lang.hitch(this, this.getCount)
      );
    },
    getCount: function(payload) {
      var url = "/share/service/com/example/doc-count"
        + "?site=" + payload.site
        + "&from=" + payload.from
        + "&to=" + payload.to;
      this.serviceXhr({
        url: url,
        method: "GET",
        alfTopic: "DOC_COUNT",
        successCallback: this.onSuccess,
        failureCallback: this.onFailure,
        callbackScope: this
      });
    },
    onSuccess: function(response, config) {
      this.alfPublish("DOC_COUNT_SUCCESS", response);
    },
    onFailure: function(err) {
      console.error("Error:", err);
    }
  });
});

