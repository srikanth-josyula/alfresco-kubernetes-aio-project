define([
   "dojo/_base/declare",
   "alfresco/services/BaseService",
   "alfresco/core/CoreXhr",
   "dojo/_base/lang"
], function(declare, BaseService, AlfXhr, lang) {
   return declare([BaseService, AlfXhr], {
      registerSubscriptions: function() {
         this.alfSubscribe("GET_HELLO_MESSAGE", lang.hitch(this, this.getHelloMessage));
      },
      getHelloMessage: function(payload) {
         var responseTopic = payload.alfResponseTopic || "GET_HELLO_MESSAGE";
         var url = window.location.protocol + "//" + window.location.host +
                   "/share/service/com/example/demo/get-message";
         var config = {
            alfTopic: responseTopic,
            url: url,
            method: "GET",
            successCallback: this.onSuccess,
            failureCallback: this.onFailure,
            callbackScope: this
         };
         this.serviceXhr(config);
      },
      onSuccess: function(response, requestConfig) {
         console.log("Service Success:", response);
         this.alfPublish(requestConfig.alfTopic + "_SUCCESS", response);
      },
      onFailure: function(response, requestConfig) {
         console.error("Service Error:", response);
         this.alfPublish(requestConfig.alfTopic + "_FAILURE", response);
      }
   });
});

