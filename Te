share/src/main/resources/META-INF/js/example/widgets/HelloLoader.js

define([
   "dojo/_base/declare",
   "dojo/_base/lang",
   "alfresco/core/Core"
], function(declare, lang, Core) {
   return declare([Core], {
      postCreate: function() {
         this.inherited(arguments);
         this.alfSubscribe(
            "HELLO_SUCCESS",
            lang.hitch(this, this.onSuccess)
         );
         this.alfPublish("ALF_XHR_REQUEST", {
            url: "service/custom/hello",
            method: "GET",
            alfResponseTopic: "HELLO_SUCCESS"
         });
      },
      onSuccess: function(payload) {
         console.log("HELLO_SUCCESS");
         console.log(payload);
      }
   });
});

