5. 🧩 WIDGET (UI + FORM)

📄 DashboardWidget.js

define([
  "dojo/_base/declare",
  "dojo/_base/lang",
  "alfresco/core/Core",
  "alfresco/forms/Form",
  "alfresco/forms/controls/TextBox",
  "alfresco/buttons/AlfButton"
], function(declare, lang, Core, Form, TextBox, AlfButton) {
  return declare([Core], {
    postCreate: function() {
      this.inherited(arguments);
      this.alfSubscribe("DOC_COUNT_SUCCESS",
        lang.hitch(this, this.showResult));
      this.form = new Form({
        widgets: [
          {
            name: "alfresco/forms/controls/TextBox",
            config: {
              fieldId: "site",
              label: "Site"
            }
          },
          {
            name: "alfresco/forms/controls/TextBox",
            config: {
              fieldId: "from",
              label: "From Date"
            }
          },
          {
            name: "alfresco/forms/controls/TextBox",
            config: {
              fieldId: "to",
              label: "To Date"
            }
          },
          {
            name: "alfresco/buttons/AlfButton",
            config: {
              label: "Submit",
              clickTopic: "DOC_COUNT_REQUEST"
            }
          }
        ]
      });
      this.form.placeAt(this.domNode);
    },
    showResult: function(payload) {
      alert("Document Count: " + payload.count);
    }
  });
});

