Yes. Aikau has a built-in date control, so you can use a form with:

* TextBox
* From Date
* To Date
* Submit button

For example, in your dashboard.get.js:

model.jsonModel = {
   widgets: [
      {
         name: "alfresco/layout/VerticalWidgets",
         config: {
            widgets: [
               {
                  name: "alfresco/forms/Form",
                  config: {
                     okButtonLabel: "Submit",
                     okButtonPublishTopic: "FORM_SUBMIT",
                     widgets: [
                        {
                           name: "alfresco/forms/controls/TextBox",
                           config: {
                              name: "siteName",
                              label: "Site Name"
                           }
                        },
                        {
                           name: "alfresco/forms/controls/DateTextBox",
                           config: {
                              name: "fromDate",
                              label: "From Date"
                           }
                        },
                        {
                           name: "alfresco/forms/controls/DateTextBox",
                           config: {
                              name: "toDate",
                              label: "To Date"
                           }
                        }
                     ]
                  }
               },
               {
                  name: "example/widgets/HelloWidget"
               }
            ]
         }
      }
   ]
};

Then your HelloWidget.js can simply subscribe:

define([
   "dojo/_base/declare",
   "dojo/_base/lang",
   "alfresco/core/Core"
], function(declare, lang, Core) {
   return declare([Core], {
      postCreate: function() {
         this.inherited(arguments);
         this.alfSubscribe(
            "FORM_SUBMIT",
            lang.hitch(this, this.onSubmit)
         );
      },
      onSubmit: function(payload) {
         console.log("Payload:", payload);
         console.log("Site:", payload.siteName);
         console.log("From:", payload.fromDate);
         console.log("To:", payload.toDate);
      }
   });
});

When the user submits the form, you’ll receive a payload similar to:

{
   siteName: "marketing",
   fromDate: "2026-06-01",
   toDate: "2026-06-30"
}

This is a good next step because once you can receive the form values in your widget, replacing the console.log with:

this.alfPublish("DOC_COUNT_REQUEST", payload);

lets your service receive exactly the same payload and call your Share Web Script.
